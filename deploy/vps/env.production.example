# Copy this file to /var/www/nexo-ride/current/.env on VPS
PORT=3333
HOST=127.0.0.1
NODE_ENV=production
DATA_DIR=/var/www/nexo-ride/current/data
UPLOAD_DIR=/var/www/nexo-ride/current/data/uploads
SERVER_URL=https://ride.nexoofficial.in
DOMAIN_NAME=ride.nexoofficial.in
DEPLOY_PROVIDER=VPS
SSL_CONFIGURED=true
APP_NAME=NEXO Ride
APP_PACKAGE_NAME=com.astratechnologies.nexoride
ADMIN_MOBILE=<ADMIN_MOBILE>
ADMIN_EMAIL=admin@example.com
SUPPORT_MOBILE=<SUPPORT_MOBILE>
SUPPORT_EMAIL=support@example.com

# CHANGE THESE BEFORE PUBLIC USE
APP_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_JWT_SECRET
ADMIN_TEMP_PASSWORD=<SET_STRONG_TEMP_PASSWORD>

# Keep demo for pilot; change later
OTP_PROVIDER=DEMO
DEMO_OTP=123456
PAYMENT_PROVIDER=DEMO
MAP_PROVIDER=DEMO
PUSH_PROVIDER=DEMO

# Optional real integrations later
DATABASE_URL=
MAPPLS_API_KEY=
GOOGLE_MAPS_API_KEY=
MSG91_AUTH_KEY=
TWOFACTOR_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MANUAL_UPI_ID=
FCM_SERVER_KEY=
FCM_WEB_VAPID_KEY=
FIREBASE_PROJECT_ID=
