# NEXO Ride production environment example
# Copy to .env on the server and fill real values. Do not commit real secrets or personal contact details.

PORT=3333
HOST=127.0.0.1
NODE_ENV=production
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
SESSION_DAYS=30
APP_PACKAGE_NAME=com.astratechnologies.nexoride
APP_NAME=NEXO Ride

# First admin bootstrap. Use real values only in server .env, not in GitHub/ZIP examples.
ADMIN_NAME=NEXO Ride Main Admin
ADMIN_MOBILE=
ADMIN_EMAIL=admin@example.com
# Must be 12+ chars. If left blank/weak, server generates a one-time password in data/INITIAL_ADMIN_CREDENTIALS.txt
ADMIN_TEMP_PASSWORD=
SUPPORT_MOBILE=
SUPPORT_EMAIL=support@example.com

# Public production URL for VPS deployment
SERVER_URL=https://ride.nexoofficial.in
DOMAIN_NAME=ride.nexoofficial.in
DEPLOY_PROVIDER=VPS
DEPLOY_BRANCH=main
SSL_CONFIGURED=true
ALLOWED_ORIGINS=https://ride.nexoofficial.in

# Security - MUST change before public launch
APP_SECRET=change_this_long_random_secret_min_32_chars
JWT_SECRET=change_this_long_random_jwt_secret_min_32_chars
SESSION_SECRET=change_this_long_random_session_secret_min_32_chars
SECURITY_ADMIN_2FA=false
SECURITY_IP_ALLOWLIST=
LOGIN_RATE_LIMIT_PER_MINUTE=8
ACCOUNT_LOCKOUT_ENABLED=true
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
ADMIN_SESSION_DAYS=7

# Database - pilot mode can use local JSON; scale mode requires PostgreSQL + Redis
DATABASE_URL=
REDIS_URL=
KYC_STORAGE_MODE=LOCAL_FILE
STORAGE_PROVIDER=LOCAL_FILE
MAX_UPLOAD_MB=10

# Map navigation production settings
MAP_PROVIDER=GOOGLE
NAVIGATION_PROVIDER=GOOGLE_WEB
GOOGLE_MAPS_API_KEY=
MAPPLS_API_KEY=

# OTP/Auth settings - production must not use DEMO
OTP_PROVIDER=TWOFACTOR
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
MAX_OTP_PER_MOBILE_PER_HOUR=5
FIREBASE_PROJECT_ID=
MSG91_AUTH_KEY=
TWOFACTOR_API_KEY=
EXPOSE_DEMO_OTP=false
ALLOW_DEMO_OTP_IN_PRODUCTION=false

# Payment settings - production must use Razorpay live/test explicitly
PAYMENT_PROVIDER=RAZORPAY
RAZORPAY_ENABLED=true
RAZORPAY_MODE=live
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_COMPANY_NAME=NEXO Ride
MANUAL_UPI_ID=
ALLOW_DEMO_PAYMENT_IN_PRODUCTION=false

# Push / Firebase settings
PUSH_PROVIDER=FCM
FCM_SERVER_KEY=
FCM_WEB_VAPID_KEY=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Passenger Google Login
GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://ride.nexoofficial.in/api/auth/google/callback

# APK/PWA cache helper
APP_CACHE_VERSION=207zrc2
